{
    "name": "@tooldepot/tool-color-palette",
    "version": "0.1.0",
    "private": true,

    "license": "Apache-2.0",
    "type": "module",
    "description": "Generate color schemes from a base color",
    "bin": {
        "td-color-palette": "./dist/cli/index.js"
    },
    "exports": {
        ".": "./dist/core/index.js",
        "./core": "./dist/core/index.js",
        "./cli": "./dist/cli/index.js",
        "./desktop": "./dist/desktop/index.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@tooldepot/types": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@types/react": "^18.3.0",
        "react": "^18.3.1",
        "typescript": "^5.9.2"
    },
    "tooldepot": {
        "id": "color-palette",
        "name": "配色方案生成",
        "description": "基于主色生成配色方案。",
        "category": "life",
        "entry": {
            "core": "./dist/core/index.js",
            "cli": "./dist/cli/index.js",
            "desktop": "./dist/desktop/index.js"
        },
        "bin": "td-color-palette"
    }
}