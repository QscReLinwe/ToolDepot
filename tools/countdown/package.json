{
  "name": "@tooldepot/tool-countdown",
  "version": "0.1.0",
  "private": true,

  "license": "Apache-2.0",
  "type": "module",
  "description": "倒计时工具：设置指定时间触发提醒",
  "bin": {
    "td-countdown": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./core": "./dist/core/index.js",
    "./cli": "./dist/cli/index.js",
    "./desktop": "./dist/desktop/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tooldepot/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "typescript": "^5.9.2"
  },
  "tooldepot": {
    "id": "countdown",
    "name": "倒计时",
    "description": "设置指定时间触发提醒",
    "category": "utility",
    "entry": {
      "core": "./dist/core/index.js",
      "cli": "./dist/cli/index.js",
      "desktop": "./dist/desktop/index.js"
    },
    "bin": "td-countdown"
  }
}