{
    "name": "@tooldepot/tool-url-codec",
    "version": "0.1.0",
    "private": true,

    "license": "Apache-2.0",
    "type": "module",
    "description": "URL 编码 / 解码工具",
    "bin": {
        "td-url-codec": "./dist/cli/index.js"
    },
    "exports": {
        ".": "./dist/core/index.js",
        "./core": "./dist/core/index.js",
        "./cli": "./dist/cli/index.js",
        "./desktop": "./dist/desktop/index.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@tooldepot/cli-core": "workspace:*",
        "@tooldepot/types": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "20.14.0",
        "@types/react": "18.3.0",
        "typescript": "^5.9.2"
    },
    "tooldepot": {
        "id": "url-codec",
        "name": "URL 编解码",
        "description": "通过 encodeURIComponent/decodeURIComponent 编解码 URL。",
        "category": "dev",
        "entry": {
            "core": "./dist/core/index.js",
            "cli": "./dist/cli/index.js",
            "desktop": "./dist/desktop/index.js"
        },
        "bin": "td-url-codec"
    }
}