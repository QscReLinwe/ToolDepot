{
    "name": "@tooldepot/tool-qr-code",
    "version": "0.1.0",
    "private": true,

    "license": "Apache-2.0",
    "type": "module",
    "description": "Generate QR code images from text",
    "bin": {
        "td-qr-code": "./dist/cli/index.js"
    },
    "exports": {
        ".": "./dist/core/index.js",
        "./core": "./dist/core/index.js",
        "./cli": "./dist/cli/index.js",
        "./desktop": "./dist/desktop/index.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@tooldepot/types": "workspace:*",
        "qrcode": "^1.5.3"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@types/qrcode": "^1.5.5",
        "@types/react": "^18.3.0",
        "react": "^18.3.1",
        "typescript": "^5.9.2"
    },
    "tooldepot": {
        "id": "qr-code",
        "name": "二维码生成",
        "description": "根据文本生成二维码图片。",
        "category": "work",
        "entry": {
            "core": "./dist/core/index.js",
            "cli": "./dist/cli/index.js",
            "desktop": "./dist/desktop/index.js"
        },
        "bin": "td-qr-code"
    }
}