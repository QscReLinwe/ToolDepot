{
  "name": "@tooldepot/tool-lunar-calendar",
  "version": "0.1.0",
  "private": true,

  "license": "Apache-2.0",
  "type": "module",
  "description": "公历转农历、生肖、节气查询",
  "bin": {
    "td-lunar-calendar": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./core": "./dist/core/index.js",
    "./cli": "./dist/cli/index.js",
    "./desktop": "./dist/desktop/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tooldepot/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "typescript": "^5.9.2"
  },
  "tooldepot": {
    "id": "lunar-calendar",
    "name": "农历 / 阴历查询",
    "description": "公历转农历、生肖、二十四节气、节日查询",
    "category": "utility",
    "entry": {
      "core": "./dist/core/index.js",
      "cli": "./dist/cli/index.js",
      "desktop": "./dist/desktop/index.js"
    },
    "bin": "td-lunar-calendar"
  }
}