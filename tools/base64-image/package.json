{
    "name": "@tooldepot/tool-base64-image",
    "version": "0.1.0",
    "private": true,

    "license": "Apache-2.0",
    "type": "module",
    "description": "Encode/decode images to/from base64 data URLs",
    "bin": {
        "td-base64-image": "./dist/cli/index.js"
    },
    "exports": {
        ".": "./dist/core/index.js",
        "./core": "./dist/core/index.js",
        "./cli": "./dist/cli/index.js",
        "./desktop": "./dist/desktop/index.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@tooldepot/types": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@types/react": "^18.3.0",
        "react": "^18.3.1",
        "typescript": "^5.9.2"
    },
    "tooldepot": {
        "id": "base64-image",
        "name": "Base64 图片",
        "description": "将图片与 Base64 Data URL 互相转换。",
        "category": "dev",
        "entry": {
            "core": "./dist/core/index.js",
            "cli": "./dist/cli/index.js",
            "desktop": "./dist/desktop/index.js"
        },
        "bin": "td-base64-image"
    }
}